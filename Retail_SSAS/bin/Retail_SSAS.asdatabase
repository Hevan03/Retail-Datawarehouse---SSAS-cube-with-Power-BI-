      <Kpis>
        <Kpi>
          <ID>KPI</ID>
          <Name>Sales Revenue Performance</Name>
          <AssociatedMeasureGroupID>Fact Sales</AssociatedMeasureGroupID>
          <Value>[Measures].[Total Amount]</Value>
          <Goal>1.1 * ([Measures].[Total Amount], [Dim Date].[Calender Hierarchy].CurrentMember.PrevMember)</Goal>
          <Status>Case  
  When [Measures].[Total Amount] &gt;= KPIGoal("Sales Revenue Performance")   
    Then 1 -- Green
  When [Measures].[Total Amount] &lt; KPIGoal("Sales Revenue Performance")   
    AND [Measures].[Total Amount] &gt;= (KPIGoal("Sales Revenue Performance") * 0.9)  
    Then 0 -- Yellow (within 90% of goal)
  Else -1 -- Red
End</Status>
          <Trend>Case  
  When [Measures].[Total Amount] &gt; 
       ([Measures].[Total Amount], [Dim Date].[Calender Hierarchy].CurrentMember.PrevMember)  
    Then 1 -- Arrow Up (Improving)
  When [Measures].[Total Amount] &lt; 
       ([Measures].[Total Amount], [Dim Date].[Calender Hierarchy].CurrentMember.PrevMember)  
    Then -1 -- Arrow Down (Declining)
  Else 0 -- Horizontal Arrow (No Change)
End</Trend>
          <TrendGraphic>Standard Arrow</TrendGraphic>
          <StatusGraphic>Traffic Light</StatusGraphic>
        </Kpi>
      </Kpis>
